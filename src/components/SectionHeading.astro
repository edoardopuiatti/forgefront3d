---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { eyebrow, title, description, centered = false } = Astro.props;
---

<div class:list={["max-w-3xl space-y-4", centered && "mx-auto text-center"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="text-3xl font-semibold text-white sm:text-4xl">{title}</h2>
  {description && <p class="text-base leading-7 text-stone-300 sm:text-lg">{description}</p>}
</div>
