<div class="panel p-6 sm:p-8" data-contact-widget>
  <!-- Integration note: connect this form to a real email or CRM workflow before launch. -->
  <form class="space-y-5" data-contact-form>
    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label class="field-label" for="contact-name">Name</label>
        <input class="field-input" id="contact-name" name="name" type="text" autocomplete="name" required />
      </div>
      <div>
        <label class="field-label" for="contact-email">Email</label>
        <input class="field-input" id="contact-email" name="email" type="email" autocomplete="email" required />
      </div>
    </div>

    <div class="grid gap-5 sm:grid-cols-2">
      <div>
        <label class="field-label" for="contact-phone">Phone <span class="text-stone-500">(optional)</span></label>
        <input class="field-input" id="contact-phone" name="phone" type="tel" autocomplete="tel" />
      </div>
      <div>
        <label class="field-label" for="contact-topic">What do you need help with?</label>
        <select class="field-input" id="contact-topic" name="topic" required>
          <option value="">Choose a topic</option>
          <option value="quote">I need a quote</option>
          <option value="replacement">I need a replacement part</option>
          <option value="prototype">I need a prototype</option>
          <option value="design-help">I do not have a 3D file yet</option>
          <option value="other">Something else</option>
        </select>
      </div>
    </div>

    <div>
      <label class="field-label" for="contact-message">Message</label>
      <textarea
        class="field-input min-h-40"
        id="contact-message"
        name="message"
        placeholder="Tell us about the part, project, or problem you are trying to solve. Non-technical descriptions are welcome."
        required
      ></textarea>
    </div>

    <button class="btn-primary w-full" type="submit">Send Message</button>
  </form>

  <div class="space-y-4" data-contact-success hidden tabindex="-1">
    <div class="inline-flex rounded-full border border-emerald-400/20 bg-emerald-400/10 px-3 py-1 text-xs font-medium text-emerald-300">
      Contact form demo complete
    </div>
    <h3 class="text-2xl font-semibold text-white">Thanks. Your message has been captured in the demo UI.</h3>
    <p class="text-sm leading-7 text-stone-300">
      Wire this form to your preferred form backend or inbox workflow before going live.
    </p>
    <button class="btn-secondary" type="button" data-contact-reset>Send another message</button>
  </div>
</div>

<script is:inline>
  const bindContactWidgets = () => {
    document.querySelectorAll("[data-contact-widget]").forEach((widget) => {
      if (widget.dataset.bound === "true") return;
      widget.dataset.bound = "true";

      const form = widget.querySelector("[data-contact-form]");
      const success = widget.querySelector("[data-contact-success]");
      const resetButton = widget.querySelector("[data-contact-reset]");

      form?.addEventListener("submit", (event) => {
        if (!form.reportValidity()) return;
        event.preventDefault();
        form.hidden = true;
        success.hidden = false;
        form.reset();
        success.focus();
      });

      resetButton?.addEventListener("click", () => {
        success.hidden = true;
        form.hidden = false;
        form.querySelector("input, select, textarea")?.focus();
      });
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindContactWidgets);
  } else {
    bindContactWidgets();
  }
</script>
