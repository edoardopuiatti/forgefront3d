---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import Container from "../components/Container.astro";
import FAQList from "../components/FAQList.astro";
import MaterialPreviewCard from "../components/MaterialPreviewCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import {
  faqs,
  fileTypes,
  galleryItems,
  homeUseCases,
  materials,
  proofPoints,
  reasons,
  site,
  steps,
  testimonials,
  trustBarItems,
} from "../data/site";

const homeStructuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.name,
  url: site.url,
  description: site.description,
  areaServed: "Local pickup and shipped orders",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "3D printing services",
    itemListElement: homeUseCases.map((item) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: item.title,
      },
    })),
  },
};
---

<BaseLayout
  title="Custom 3D Printed Parts"
  description="Upload a file and request a quote for replacement parts, prototypes, custom prints, and small batches."
  pathname="/"
  structuredData={homeStructuredData}
>
  <section class="overflow-hidden border-b border-white/10">
    <Container>
      <div class="grid gap-10 py-16 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:py-24">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="eyebrow">Fast, practical 3D printing</p>
            <h1 class="max-w-4xl text-5xl font-semibold text-white sm:text-6xl">
              Custom 3D printed parts for one-offs, prototypes, and small batches.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-stone-300">
              Upload a file and request a quote for replacement parts, functional prints, prototype
              housings, hobby projects, and short-run custom jobs. Every request is reviewed by a
              real person before printing starts.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <ButtonLink href="/quote/#quote-form">Upload Your File</ButtonLink>
            <ButtonLink href="/quote/" variant="secondary">Request a Quote</ButtonLink>
          </div>

          <div class="space-y-3">
            <p class="text-sm font-medium text-stone-300">
              Supported files: {fileTypes.join(", ")}
            </p>
            <div class="flex flex-wrap gap-2">
              {fileTypes.map((type) => (
                <span class="badge">{type}</span>
              ))}
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {trustBarItems.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-3 text-sm text-stone-300">
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="hero-grid rounded-[2rem] border border-white/10 bg-stone-900/70 p-6 sm:p-8">
          <div class="panel-soft p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-stone-400">How to get started</p>
            <ol class="mt-6 space-y-5">
              <li class="border-b border-white/10 pb-5">
                <p class="text-sm font-semibold text-white">1. Upload your model or describe the part</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  Send an STL, STEP, OBJ, or 3MF file. No model yet? A sketch or reference photo is
                  still useful.
                </p>
              </li>
              <li class="border-b border-white/10 pb-5">
                <p class="text-sm font-semibold text-white">2. Receive a quote and material guidance</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  The job is reviewed for size, strength, finish expectations, and turnaround.
                </p>
              </li>
              <li>
                <p class="text-sm font-semibold text-white">3. Approve the job and we print it</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  Pickup or shipping can be arranged once the part passes a final check.
                </p>
              </li>
            </ol>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Best for</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">
                Replacement parts, prototypes, small batch components, and custom one-offs.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Response time</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">{site.responseTime}</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="How It Works"
        title="A simple quote-to-print process."
        description="This service is designed for customers who want a straightforward answer, not a complicated manufacturing portal."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {steps.map((step, index) => (
          <article class="panel p-6">
            <div class="flex items-center gap-4">
              <span class="flex h-11 w-11 items-center justify-center rounded-full border border-amber-300/30 bg-amber-300/10 text-sm font-semibold text-amber-300">
                0{index + 1}
              </span>
              <h3 class="text-xl font-semibold text-white">{step.title}</h3>
            </div>
            <p class="mt-5 text-sm leading-7 text-stone-300">{step.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="What We Print"
        title="Useful parts for real jobs."
        description="From broken part replacements to prototype housings, the focus is on custom prints that solve a practical problem."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {homeUseCases.map((item) => (
          <article class="panel-soft p-6">
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{item.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          eyebrow="Materials Preview"
          title="Common materials for functional and detail-focused parts."
          description="Material choice affects strength, finish, cost, and how the part will behave in real use."
        />
        <ButtonLink href="/materials-finishes/" variant="secondary">View All Materials</ButtonLink>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-4">
        {materials.map((material) => (
          <MaterialPreviewCard material={material} />
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="Why Choose Us"
        title="Small-shop service without small-shop uncertainty."
        description="The advantage of a personal print service is that you can ask questions, get practical guidance, and order low-volume jobs without a factory-scale workflow."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {reasons.map((reason) => (
          <article class="panel-soft p-6">
            <h3 class="text-xl font-semibold text-white">{reason.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{reason.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="Example Work"
        title="A gallery ready for real print photography."
        description="The layout is complete now, and these placeholders can be swapped for real part photos without redesigning the page."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {galleryItems.map((item, index) => (
          <article class:list={["panel-soft overflow-hidden", index % 3 === 0 && "xl:row-span-2"]}>
            <div class:list={["flex min-h-64 items-end bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.02)),linear-gradient(135deg,rgba(245,158,11,0.18),transparent_55%)] p-6", index % 3 === 0 && "min-h-96"]}>
              <div>
                <p class="text-xs uppercase tracking-[0.24em] text-stone-400">Placeholder image area</p>
                <h3 class="mt-3 text-xl font-semibold text-white">{item.label}</h3>
                <p class="mt-2 text-sm text-stone-300">{item.note}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <div>
          <SectionHeading
            eyebrow="Customer Trust"
            title="Built to feel clear, reliable, and easy to work with."
            description="Use real customer feedback here before launch. The sample cards below are placeholders that show the intended tone and layout."
          />
          <div class="mt-8 space-y-4">
            {proofPoints.map((point) => (
              <article class="panel-soft p-5">
                <h3 class="text-base font-semibold text-white">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-stone-300">{point.description}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="grid gap-5">
          {testimonials.map((item) => (
            <blockquote class="panel p-6">
              <p class="text-base leading-7 text-stone-100">"{item.quote}"</p>
              <footer class="mt-5 text-sm text-stone-400">{item.name}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          eyebrow="FAQ"
          title="Common questions before you upload a file."
          description="A few fast answers for first-time customers and repeat buyers."
        />
        <ButtonLink href="/faq/" variant="secondary">View Full FAQ</ButtonLink>
      </div>
      <div class="mt-10">
        <FAQList items={faqs.slice(0, 6)} firstOpen={0} />
      </div>
    </Container>
  </section>

  <section class="section-shell border-t border-white/10">
    <Container>
      <div class="panel overflow-hidden">
        <div class="grid gap-8 p-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:p-10">
          <div class="space-y-4">
            <p class="eyebrow">Ready To Start?</p>
            <h2 class="text-3xl font-semibold text-white sm:text-4xl">
              Need a part printed? Upload your file and request a quote.
            </h2>
            <p class="max-w-2xl text-base leading-7 text-stone-300">
              Straightforward jobs can move quickly, and non-technical customers are welcome. Send
              the file if you have it, or send a clear description if you do not.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <ButtonLink href="/quote/#quote-form">Upload Your File</ButtonLink>
            <ButtonLink href="/contact/" variant="secondary">Contact Us For A Custom Job</ButtonLink>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
