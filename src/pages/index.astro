---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import Container from "../components/Container.astro";
import MaterialPreviewCard from "../components/MaterialPreviewCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import {
  faqs,
  fileTypes,
  galleryItems,
  homeUseCases,
  materials,
  proofPoints,
  reasons,
  site,
  steps,
  testimonials,
  trustBarItems,
} from "../data/site";

// Server-side rewrite removed: keep root (/) as the English homepage
// Language switching is handled by separate `/cs/` pages and the header links.

const homeStructuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: site.name,
  url: "https://forgefront3d.com/",
  description: site.description,
  areaServed: "Prague pickup and shipped orders",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "3D printing services",
    itemListElement: homeUseCases.map((item) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: item.title,
      },
    })),
  },
};
---

<BaseLayout
  title="Custom 3D printing service"
  description="Fast, practical 3D printing for replacement parts, prototypes, custom jobs, and short-run production in Prague. Upload a file and request a quote."
  pathname="/"
  locale="en"
  structuredData={homeStructuredData}
>
  <section class="overflow-hidden border-b border-white/10">
    <Container>
      <div class="grid gap-10 py-16 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:py-24">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="eyebrow">Fast and practical 3D printing</p>
            <h1 class="max-w-4xl text-5xl font-semibold text-white sm:text-6xl">
              Custom 3D printed parts for prototypes, replacement pieces, and short-run production.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-stone-300">
              Upload a file and request a quote for replacement parts, functional prototypes, hobby projects, and small custom runs in PLA, PETG, or ASA.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <ButtonLink href="/quote/#quote-form">Upload Your File</ButtonLink>
            <ButtonLink href="/quote/" variant="secondary">Request a Quote</ButtonLink>
          </div>

          <div class="space-y-3">
            <p class="text-sm font-medium text-stone-300">
              Supported file types: {fileTypes.join(", ")}
            </p>
            <div class="flex flex-wrap gap-2">
              {fileTypes.map((type) => (
                <span class="badge">{type}</span>
              ))}
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {trustBarItems.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-3 text-sm text-stone-300">
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="hero-grid rounded-[2rem] border border-white/10 bg-stone-900/70 p-6 sm:p-8">
          <div class="panel-soft p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-stone-400">How it works</p>
            <ol class="mt-6 space-y-5">
              {steps.map((step, index) => (
                <li class={index < steps.length - 1 ? "border-b border-white/10 pb-5" : ""}>
                  <p class="text-sm font-semibold text-white">{index + 1}. {step.title}</p>
                  <p class="mt-2 text-sm leading-6 text-stone-400">{step.description}</p>
                </li>
              ))}
            </ol>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Best for</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">
                Replacement parts, prototypes, short runs, and custom one-offs.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Pickup</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">Prague 2 by appointment</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 sm:col-span-2">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Response</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">{site.responseTime}</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="How it works"
        title="A simple process from quote to printed part."
        description="This service is designed for customers who want a clear response and practical guidance, not a complicated factory portal."
      />

      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {steps.map((step, index) => (
          <article class="panel p-6">
            <div class="flex items-center gap-4">
              <span class="flex h-11 w-11 items-center justify-center rounded-full border border-amber-300/30 bg-amber-300/10 text-sm font-semibold text-amber-300">
                0{index + 1}
              </span>
              <h3 class="text-xl font-semibold text-white">{step.title}</h3>
            </div>
            <p class="mt-5 text-sm leading-7 text-stone-300">{step.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="What we print"
        title="Useful parts for real use."
        description="From replacement pieces to prototype housings, the aim is custom prints that solve an actual problem."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {homeUseCases.map((item) => (
          <article class="panel-soft p-6">
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{item.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          eyebrow="Materials"
          title="Common materials for functional and visual parts."
          description="Material choice affects strength, finish, cost, and how the part behaves in use."
        />
        <ButtonLink href="/materials-finishes/" variant="secondary">View all materials</ButtonLink>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
        {materials.map((material) => (
          <MaterialPreviewCard material={material} />
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="Why choose us"
        title="A small service without uncertainty."
        description="Personalized 3D printing means you can ask questions, get practical material advice, and order small jobs without factory workflows."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {reasons.map((reason) => (
          <article class="panel-soft p-6">
            <h3 class="text-xl font-semibold text-white">{reason.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{reason.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="Work examples"
        title="A gallery ready for real print photos."
        description="The layout is in place now and can be upgraded with actual part imagery later."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {galleryItems.map((item, index) => (
          <article class:list={["panel-soft overflow-hidden", index % 3 === 0 && "xl:row-span-2"]}>
            <div
              class:list={["relative flex min-h-64 items-end p-6", index % 3 === 0 && "min-h-96"]}
              style={{ backgroundImage: `url('${item.url}')`, backgroundSize: 'cover', backgroundPosition: 'center' }}
            >
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent"></div>
              <div class="relative">
                <h3 class="text-xl font-semibold text-white">{item.label}</h3>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <div>
          <SectionHeading
            eyebrow="Trust"
            title="A website built to feel clear and reliable."
            description="Before launch, add actual customer references here. Below are example cards showing the intended tone and layout."
          />
          <div class="mt-8 space-y-4">
            {proofPoints.map((point) => (
              <article class="panel-soft p-5">
                <h3 class="text-base font-semibold text-white">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-stone-300">{point.description}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="grid gap-5">
          {testimonials.map((item) => (
            <blockquote class="panel p-6">
              <p class="text-base leading-7 text-stone-100">"{item.quote}"</p>
              <footer class="mt-5 text-sm text-stone-400">{item.name}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
