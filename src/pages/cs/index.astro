---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ButtonLink from "../../components/ButtonLink.astro";
import Container from "../../components/Container.astro";
import FAQList from "../../components/FAQList.astro";
import MaterialPreviewCard from "../../components/MaterialPreviewCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import {
  faqsCs,
  fileTypesCs,
  galleryItemsCs,
  homeUseCasesCs,
  materialsCs,
  proofPointsCs,
  reasonsCs,
  siteCs,
  stepsCs,
  testimonialsCs,
  trustBarItemsCs,
} from "../../data/site-cs";

const homeStructuredData = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: siteCs.name,
  url: "https://forgefront3d.com/cs/",
  description: siteCs.description,
  areaServed: "Prague 2 pickup and shipped orders",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "3D tiskové služby",
    itemListElement: homeUseCasesCs.map((item) => ({
      "@type": "Offer",
      itemOffered: {
        "@type": "Service",
        name: item.title,
      },
    })),
  },
};
---

<BaseLayout
  title="Zakázkový 3D tisk"
  description="Nahrajte soubor a vyžádejte si cenovou nabídku na náhradní díly, prototypy, zakázkové výtisky a malé série s vyzvednutím v Praze 2 nebo zasláním."
  pathname="/cs/"
  locale="cs"
  structuredData={homeStructuredData}
>
  <section class="overflow-hidden border-b border-white/10">
    <Container>
      <div class="grid gap-10 py-16 lg:grid-cols-[1.15fr_0.85fr] lg:items-center lg:py-24">
        <div class="space-y-8">
          <div class="space-y-5">
            <p class="eyebrow">Rychlý a praktický 3D tisk</p>
            <h1 class="max-w-4xl text-5xl font-semibold text-white sm:text-6xl">
              Zakázkově tištěné 3D díly pro kusovou výrobu, prototypy a malé série.
            </h1>
            <p class="max-w-2xl text-lg leading-8 text-stone-300">
              Nahrajte soubor a vyžádejte si nabídku na náhradní díly, funkční výtisky,
              prototypové kryty, hobby projekty a malé zakázkové série v PLA, PETG nebo ASA.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <ButtonLink href="/cs/quote/#quote-form">Nahrát soubor</ButtonLink>
            <ButtonLink href="/cs/quote/" variant="secondary">Vyžádat nabídku</ButtonLink>
          </div>

          <div class="space-y-3">
            <p class="text-sm font-medium text-stone-300">
              Podporované soubory: {fileTypesCs.join(", ")}
            </p>
            <div class="flex flex-wrap gap-2">
              {fileTypesCs.map((type) => (
                <span class="badge">{type}</span>
              ))}
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            {trustBarItemsCs.map((item) => (
              <div class="rounded-2xl border border-white/10 bg-white/[0.035] px-4 py-3 text-sm text-stone-300">
                {item}
              </div>
            ))}
          </div>
        </div>

        <div class="hero-grid rounded-[2rem] border border-white/10 bg-stone-900/70 p-6 sm:p-8">
          <div class="panel-soft p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-stone-400">Jak začít</p>
            <ol class="mt-6 space-y-5">
              <li class="border-b border-white/10 pb-5">
                <p class="text-sm font-semibold text-white">1. Nahrajte model nebo popište díl</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  Pošlete STL, STEP, OBJ nebo 3MF. Pokud model nemáte, často stačí náčrt nebo referenční fotka.
                </p>
              </li>
              <li class="border-b border-white/10 pb-5">
                <p class="text-sm font-semibold text-white">2. Dostanete nabídku a doporučení materiálu</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  Zakázku zhodnotíme podle velikosti, pevnosti, vzhledu a podle toho, jestli je vhodnější PLA, PETG nebo ASA.
                </p>
              </li>
              <li>
                <p class="text-sm font-semibold text-white">3. Schválíte nabídku a díl vytiskneme</p>
                <p class="mt-2 text-sm leading-6 text-stone-400">
                  Po kontrole domluvíme zaslání nebo osobní vyzvednutí v Praze 2.
                </p>
              </li>
            </ol>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Vhodné pro</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">
                Náhradní díly, prototypy, malé série a zakázkové jednotlivé kusy.
              </p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Vyzvednutí</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">Praha 2 po domluvě</p>
            </div>
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4 sm:col-span-2">
              <p class="text-xs uppercase tracking-[0.2em] text-stone-500">Odezva</p>
              <p class="mt-3 text-sm leading-6 text-stone-200">{siteCs.responseTime}</p>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="Jak to funguje"
        title="Jednoduchý proces od poptávky po hotový díl."
        description="Služba je navržená pro zákazníky, kteří chtějí rychlou a srozumitelnou odpověď, ne složitý výrobní portál."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-3">
        {stepsCs.map((step, index) => (
          <article class="panel p-6">
            <div class="flex items-center gap-4">
              <span class="flex h-11 w-11 items-center justify-center rounded-full border border-amber-300/30 bg-amber-300/10 text-sm font-semibold text-amber-300">
                0{index + 1}
              </span>
              <h3 class="text-xl font-semibold text-white">{step.title}</h3>
            </div>
            <p class="mt-5 text-sm leading-7 text-stone-300">{step.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="Co tiskneme"
        title="Užitečné díly pro reálné použití."
        description="Od náhradních dílů po prototypové kryty. Cílem jsou zakázkové výtisky, které řeší konkrétní problém."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-5">
        {homeUseCasesCs.map((item) => (
          <article class="panel-soft p-6">
            <h3 class="text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{item.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          eyebrow="Materiály"
          title="Běžné materiály pro funkční i pohledové díly."
          description="Volba materiálu ovlivňuje pevnost, vzhled, cenu i chování dílu v praxi."
        />
        <ButtonLink href="/cs/materials-finishes/" variant="secondary">Zobrazit všechny materiály</ButtonLink>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-2 xl:grid-cols-3">
        {materialsCs.map((material) => (
          <MaterialPreviewCard material={material} />
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <SectionHeading
        eyebrow="Proč právě my"
        title="Malá služba bez nejistoty."
        description="Výhodou osobního 3D tisku je možnost ptát se, dostat praktické doporučení a objednat i malé zakázky bez továrního workflow."
      />
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        {reasonsCs.map((reason) => (
          <article class="panel-soft p-6">
            <h3 class="text-xl font-semibold text-white">{reason.title}</h3>
            <p class="mt-4 text-sm leading-7 text-stone-300">{reason.description}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <SectionHeading
        eyebrow="Ukázky práce"
        title="Galerie připravená na reálné fotografie výtisků."
        description="Rozvržení je hotové už teď a placeholdery lze jednoduše nahradit skutečnými fotkami dílů."
      />
      <div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {galleryItemsCs.map((item, index) => (
          <article class:list={["panel-soft overflow-hidden", index % 3 === 0 && "xl:row-span-2"]}>
            <div class:list={["flex min-h-64 items-end bg-[linear-gradient(180deg,rgba(255,255,255,0.04),rgba(255,255,255,0.02)),linear-gradient(135deg,rgba(245,158,11,0.18),transparent_55%)] p-6", index % 3 === 0 && "min-h-96"]}>
              <div>
                <p class="text-xs uppercase tracking-[0.24em] text-stone-400">Místo pro fotografii</p>
                <h3 class="mt-3 text-xl font-semibold text-white">{item.label}</h3>
                <p class="mt-2 text-sm text-stone-300">{item.note}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <section class="section-shell border-y border-white/10 bg-black/20">
    <Container>
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
        <div>
          <SectionHeading
            eyebrow="Důvěra"
            title="Web navržený tak, aby působil jasně a spolehlivě."
            description="Před spuštěním sem doplňte reálné reference zákazníků. Níže jsou ukázkové karty, které ukazují zamýšlený tón a rozvržení."
          />
          <div class="mt-8 space-y-4">
            {proofPointsCs.map((point) => (
              <article class="panel-soft p-5">
                <h3 class="text-base font-semibold text-white">{point.title}</h3>
                <p class="mt-2 text-sm leading-6 text-stone-300">{point.description}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="grid gap-5">
          {testimonialsCs.map((item) => (
            <blockquote class="panel p-6">
              <p class="text-base leading-7 text-stone-100">"{item.quote}"</p>
              <footer class="mt-5 text-sm text-stone-400">{item.name}</footer>
            </blockquote>
          ))}
        </div>
      </div>
    </Container>
  </section>

  <section class="section-shell">
    <Container>
      <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
        <SectionHeading
          eyebrow="FAQ"
          title="Časté otázky před odesláním souboru."
          description="Pár rychlých odpovědí pro první objednávku i opakované zákazníky."
        />
        <ButtonLink href="/cs/faq/" variant="secondary">Celé FAQ</ButtonLink>
      </div>
      <div class="mt-10">
        <FAQList items={faqsCs.slice(0, 6)} firstOpen={0} />
      </div>
    </Container>
  </section>

  <section class="section-shell border-t border-white/10">
    <Container>
      <div class="panel overflow-hidden">
        <div class="grid gap-8 p-8 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:p-10">
          <div class="space-y-4">
            <p class="eyebrow">Připravení začít?</p>
            <h2 class="text-3xl font-semibold text-white sm:text-4xl">
              Potřebujete vytisknout díl? Nahrajte soubor a vyžádejte si nabídku.
            </h2>
            <p class="max-w-2xl text-base leading-7 text-stone-300">
              Jednodušší zakázky mohou být vyřízené rychle a není problém, pokud nejste technický zákazník. Pošlete soubor, nebo aspoň jasný popis.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 lg:justify-end">
            <ButtonLink href="/cs/quote/#quote-form">Nahrát soubor</ButtonLink>
            <ButtonLink href="/cs/contact/" variant="secondary">Kontakt pro zakázku na míru</ButtonLink>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
