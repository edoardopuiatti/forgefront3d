---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { siteCs } from "../../../data/site-cs";

const posts = (await getCollection("blog"))
  .filter((post) => post.id.startsWith("cs/"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getPostHref = (id: string) => `/cs/blog/${id.replace(/^cs\//, "")}/`;

const title = "Blog";
const description = "Nejnovější novinky a poznatky o 3D tisku od Forgefront 3D";
---

<BaseLayout title={title} description={description} pathname="/cs/blog/" locale="cs">
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <header class="text-center mb-12">
          <h1 class="text-4xl font-bold text-gray-900 mb-4">Blog</h1>
          <p class="text-xl text-gray-600">
            Buďte v obraze s nejnovějšími novinkami, tipy a poznatky o 3D tisku
          </p>
        </header>

        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
              {post.data.heroImage && (
                <img
                  src={post.data.heroImage}
                  alt={post.data.title}
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-6">
                <h2 class="text-xl font-semibold text-gray-900 mb-2">
                  <a
                    href={getPostHref(post.id)}
                    class="hover:text-blue-600 transition-colors"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 mb-4">{post.data.description}</p>
                <div class="flex items-center text-sm text-gray-500">
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString("cs-CZ", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                  {post.data.updatedDate && (
                    <span class="ml-2">
                      (Aktualizováno{" "}
                      {post.data.updatedDate.toLocaleDateString("cs-CZ", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                      )
                    </span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
