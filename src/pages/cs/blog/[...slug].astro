---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description} pathname={`/cs/blog/${post.id}/`} locale="cs">
  <article class="section-shell">
    <div class="container-shell">
      <div class="grid gap-10 xl:grid-cols-[1fr_320px]">
        <div class="space-y-10">
          <div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-8 shadow-[0_24px_80px_rgba(0,0,0,0.22)]">
            <div class="text-sm uppercase tracking-[0.28em] text-amber-300">Blog</div>
            <h1 class="mt-4 text-4xl font-semibold text-white sm:text-5xl">
              {post.data.title}
            </h1>
            <p class="mt-4 max-w-3xl text-lg leading-8 text-stone-300">
              {post.data.description}
            </p>
            <div class="mt-6 flex flex-wrap gap-4 text-sm text-stone-400">
              <time datetime={post.data.pubDate.toISOString()}>
                Publikováno {post.data.pubDate.toLocaleDateString("cs-CZ", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </time>
              {post.data.updatedDate && (
                <span>
                  Aktualizováno {post.data.updatedDate.toLocaleDateString("cs-CZ", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </span>
              )}
              <span>Forgefront 3D</span>
            </div>
          </div>

          {post.data.heroImage && (
            <div class="overflow-hidden rounded-[2rem] border border-white/10 bg-white/[0.03]">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-72 object-cover"
              />
            </div>
          )}

          <div class="prose prose-invert prose-lg max-w-none">
            <Content />
          </div>

          <footer class="mt-12 border-t border-white/10 pt-8">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <a href="/cs/blog/" class="btn-secondary w-fit">← Zpět na Blog</a>
              <a href="/cs/quote/" class="btn-primary w-fit">Získat nabídku</a>
            </div>
          </footer>
        </div>

        <aside class="space-y-6">
          <div class="sticky top-24 rounded-[2rem] border border-white/10 bg-white/[0.04] p-8 shadow-[0_18px_40px_rgba(0,0,0,0.20)]">
            <p class="text-xs uppercase tracking-[0.28em] text-amber-300">Potřebujete díl?</p>
            <h2 class="mt-4 text-2xl font-semibold text-white">
              Získejte radu o materiálu a cenovou nabídku.
            </h2>
            <p class="mt-4 text-sm leading-6 text-stone-300">
              Nahrajte soubor nebo popište díl a my doporučíme správný materiál, povrch a termín.
            </p>
            <a href="/cs/quote/" class="btn-primary w-full justify-center mt-6">
              Požádat o nabídku
            </a>
          </div>

          <div class="rounded-[2rem] border border-white/10 bg-white/[0.03] p-6">
            <h3 class="text-base font-semibold text-white">Co můžete čekat</h3>
            <ul class="mt-4 space-y-3 text-sm leading-6 text-stone-300">
              <li>Rychlé posouzení realitou ověřenou osobou</li>
              <li>Doporučení materiálu pro pevnost a povrch</li>
              <li>Osobní vyzvednutí v Praze nebo zaslání poštou</li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>